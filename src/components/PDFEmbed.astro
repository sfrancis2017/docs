---
interface Props {
  src: string;
  height?: number;
  title?: string;
}
const { src, height = 480, title = 'Embedded PDF' } = Astro.props;
---

<figure class="pdf-embed">
  <iframe
    src={`${src}#toolbar=1&view=FitH`}
    title={title}
    width="100%"
    height={height}
    loading="lazy"
  ></iframe>
  <figcaption>
    <a href={src} target="_blank" rel="noopener">View original PDF ↗</a>
  </figcaption>
</figure>

<style>
  .pdf-embed {
    margin: 1.5rem 0;
  }
  .pdf-embed iframe {
    border: 1px solid var(--sl-color-hairline);
    border-radius: 0.5rem;
    background: var(--sl-color-bg-inline-code);
  }
  .pdf-embed figcaption {
    text-align: right;
    font-size: 0.875rem;
    margin-top: 0.25rem;
  }
</style>
