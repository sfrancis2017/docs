---
import Search from '@astrojs/starlight/components/Search.astro';
import ThemeSelect from '@astrojs/starlight/components/ThemeSelect.astro';
import SocialIcons from '@astrojs/starlight/components/SocialIcons.astro';
import MobileMenuToggle from '@astrojs/starlight/components/MobileMenuToggle.astro';
---

<header class="site-bridge">
  <div class="site-bridge-inner">
    <a
      href="https://sajivfrancis.com/"
      class="bridge-logo"
      aria-label="Sajiv Francis — home"
    >
      <img src="/img/logo.png" alt="" width="45" height="36" />
    </a>

    <nav class="bridge-nav" aria-label="Site navigation">
      <a href="https://sajivfrancis.com/">Home</a>
      <a href="https://sajivfrancis.com/blog/">Writing</a>
      <a href="https://sajivfrancis.com/about/">About</a>
      <a href="https://sajivfrancis.com/chat/">Chat</a>
      <span class="bridge-current" aria-current="page">Docs</span>
    </nav>

    <div class="bridge-actions">
      <div class="bridge-search">
        <Search />
      </div>
      <SocialIcons />
      <ThemeSelect />
      <div class="bridge-mobile-only">
        <MobileMenuToggle />
      </div>
    </div>
  </div>
</header>

<style>
  .site-bridge {
    background: var(--sl-color-bg-nav);
    height: 100%;
    /* Outer Starlight wrapper already provides border-bottom + fixed positioning */
  }

  .site-bridge-inner {
    max-width: 80rem;
    height: 100%;
    margin: 0 auto;
    padding: 0 1.5rem;
    display: flex;
    align-items: center;
    gap: 1rem;
    font-size: 0.8125rem;
  }

  .bridge-logo {
    flex-shrink: 0;
    display: inline-flex;
    align-items: center;
  }

  .bridge-logo img {
    height: 28px;
    width: auto;
  }

  .bridge-nav {
    display: flex;
    align-items: center;
    gap: 1.25rem;
  }

  .bridge-nav a {
    color: var(--sl-color-gray-3);
    text-decoration: none;
    transition: color 200ms ease;
  }

  .bridge-nav a:hover {
    color: var(--sl-color-text);
  }

  .bridge-current {
    color: var(--sl-color-text);
    font-weight: 500;
  }

  .bridge-actions {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-shrink: 0;
    margin-left: auto;
  }

  .bridge-mobile-only {
    display: none;
  }

  /* Tablet and below: hide cross-site nav, show hamburger */
  @media (max-width: 50rem) {
    .site-bridge-inner {
      padding: 0 1rem;
      gap: 0.75rem;
    }
    .bridge-logo img {
      height: 24px;
    }
    .bridge-nav {
      display: none;
    }
    .bridge-mobile-only {
      display: flex;
    }
  }
</style>
