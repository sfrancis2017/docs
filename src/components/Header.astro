---
import Default from '@astrojs/starlight/components/Header.astro';
---

<div class="site-bridge">
  <div class="site-bridge-inner">
    <a href="https://sajivfrancis.com/" class="bridge-logo" aria-label="Sajiv Francis — home">
      <img src="/img/logo.png" alt="" width="22" height="22" />
      <span>Sajiv Francis</span>
    </a>
    <nav class="bridge-nav" aria-label="Cross-site navigation">
      <a href="https://sajivfrancis.com/">Home</a>
      <a href="https://sajivfrancis.com/blog/">Writing</a>
      <a href="https://sajivfrancis.com/about/">About</a>
      <a href="https://sajivfrancis.com/chat/">Chat</a>
      <span class="bridge-current" aria-current="page">Docs</span>
    </nav>
  </div>
</div>

<Default><slot /></Default>

<style>
  .site-bridge {
    background: var(--sl-color-bg-nav);
    border-bottom: 1px solid var(--sl-color-hairline);
    font-size: 0.8125rem;
  }

  .site-bridge-inner {
    max-width: var(--sl-content-width);
    margin: 0 auto;
    padding: 0.5rem 1rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }

  .bridge-logo {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--sl-color-text);
    text-decoration: none;
    font-weight: 600;
    letter-spacing: -0.01em;
  }

  .bridge-logo:hover { color: var(--sl-color-text-accent); }
  .bridge-logo img { height: 20px; width: auto; flex-shrink: 0; }

  .bridge-nav {
    display: flex;
    align-items: center;
    gap: 1.25rem;
  }

  .bridge-nav a {
    color: var(--sl-color-gray-3);
    text-decoration: none;
    transition: color 200ms ease;
  }

  .bridge-nav a:hover { color: var(--sl-color-text); }

  .bridge-current {
    color: var(--sl-color-text);
    font-weight: 500;
  }

  @media (max-width: 50rem) {
    .site-bridge-inner { padding: 0.5rem 0.75rem; }
    .bridge-logo span { display: none; }
    .bridge-nav { gap: 0.875rem; font-size: 0.75rem; }
  }

  @media (max-width: 30rem) {
    .bridge-nav { gap: 0.625rem; }
  }
</style>
